#!/usr/bin/env bash
set -euo pipefail

WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat >&2 <<EOF
Usage: dc <command>

Commands:
  build     Build the devcontainer image
  up        Start the devcontainer (build if needed)
  exec      Open a shell inside the running devcontainer
  down      Stop and remove the devcontainer
  rebuild   Force a clean rebuild (stop, remove image, start)
  help      Show this help message
EOF
}

cmd_build() {
  devcontainer build --workspace-folder "${WORKSPACE_ROOT}"
}

cmd_up() {
  devcontainer up --workspace-folder "${WORKSPACE_ROOT}"
}

cmd_exec() {
  devcontainer exec --workspace-folder "${WORKSPACE_ROOT}" bash -l
}

cmd_down() {
  local container_id=""
  container_id="$(docker ps -aq --filter "label=devcontainer.local_folder=${WORKSPACE_ROOT}" | head -1)"
  if [[ -n "${container_id}" ]]; then
    docker rm -f "${container_id}"
  else
    echo "dc: no running devcontainer found for ${WORKSPACE_ROOT}" >&2
  fi
}

cmd_rebuild() {
  devcontainer up --workspace-folder "${WORKSPACE_ROOT}" --remove-existing-container
}

main() {
  local command="${1:-help}"

  case "${command}" in
    build)   cmd_build   ;;
    up)      cmd_up      ;;
    exec)    cmd_exec    ;;
    down)    cmd_down    ;;
    rebuild) cmd_rebuild ;;
    help|--help|-h) usage ;;
    *)
      echo "dc: unknown command '${command}'" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
