#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
readonly VERSION_FILE="${REPO_ROOT}/VERSION"

if [[ ! -f "${VERSION_FILE}" ]]; then
  printf 'ERROR: expected %s to exist\n' "${VERSION_FILE}" >&2
  exit 1
fi

if ! cmp -s "${VERSION_FILE}" <(printf '0.1.0\n'); then
  printf 'ERROR: %s does not contain exactly 0.1.0 followed by one newline\n' "${VERSION_FILE}" >&2
  printf 'Actual bytes:\n' >&2
  od -An -tx1 -v "${VERSION_FILE}" >&2
  exit 1
fi

printf 'PASS: %s contains the exact expected payload\n' "${VERSION_FILE}"
