#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

readonly DEFAULT_IMAGE="${AE_IMAGE:-agent-runner}"
readonly DEFAULT_REMOTE="${AE_REMOTE:-archive}"
readonly SHA_PROMPT="Print the current working directory and git short SHA, then exit."
readonly GRAPHITE_PROMPT="Use the installed gt CLI to validate Graphite in this environment without modifying repository state. Return a short plain-text summary with: the gt version, whether ~/.config/graphite is present, and whether a non-interactive Graphite command such as 'gt log --help' works in the current repository. Do not run any command that initializes or changes Graphite repo state. If any check fails, say so plainly."
readonly GH_PROMPT="Use the installed gh CLI to confirm authentication in this environment. Return a short plain-text summary of the authenticated GitHub account and hosts. If authentication is unavailable, say so plainly."
readonly LINEAR_PROMPT="Use the installed linear CLI to list accessible Linear projects from this environment. Return only the project names, one per line. If none are accessible, say so plainly."

usage() {
  cat <<EOF
Usage: ${SCRIPT_NAME} [test...]

Run the recent local proofs for the agent runner container.

Tests:
  build           Rebuild the ${DEFAULT_IMAGE} image.
  gt-help         Run gt --version directly in the container.
  gh-help         Run gh --help directly in the container.
  linear-help     Run linear --help directly in the container.
  codex-sha       Run the Codex working-directory and git-SHA proof.
  claude-sha      Run the Claude working-directory and git-SHA proof.
  codex-graphite  Ask Codex to validate Graphite CLI and mount state read-only.
  claude-graphite Ask Claude to validate Graphite CLI and mount state read-only.
  codex-gh        Ask Codex to verify GitHub CLI auth.
  claude-gh       Ask Claude to verify GitHub CLI auth.
  codex-linear    Ask Codex to list accessible Linear projects.
  claude-linear   Ask Claude to list accessible Linear projects.
  all             Run every test above in order.

Environment:
  AE_IMAGE        Docker image name. Default: ${DEFAULT_IMAGE}
  AE_REMOTE       Git remote to clone. Default: ${DEFAULT_REMOTE}
  GITHUB_TOKEN    Optional GitHub token passed through to the container.

Examples:
  ${SCRIPT_NAME}
  ${SCRIPT_NAME} build gh-help linear-help
  AE_REMOTE=archive ${SCRIPT_NAME} codex-sha claude-sha
EOF
}

log() {
  printf '\n==> %s\n' "${*}"
}

die() {
  printf 'ERROR: %s\n' "${*}" >&2
  exit 1
}

run_build() {
  log "Building ${DEFAULT_IMAGE}"
  docker build -t "${DEFAULT_IMAGE}" docker/agent-runner
}

run_gt_help() {
  log "Running direct Graphite CLI proof"
  docker run --rm --entrypoint gt "${DEFAULT_IMAGE}" --version
}

run_gh_help() {
  log "Running direct GitHub CLI proof"
  docker run --rm --entrypoint gh "${DEFAULT_IMAGE}" --help
}

run_linear_help() {
  log "Running direct Linear CLI proof"
  docker run --rm --entrypoint linear "${DEFAULT_IMAGE}" --help
}

run_codex_sha() {
  log "Running Codex working-directory and git-SHA proof"
  AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${SHA_PROMPT}" \
    bash scripts/agent-exec
}

run_claude_sha() {
  log "Running Claude working-directory and git-SHA proof"
  AE_TOOL=claude \
    AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${SHA_PROMPT}" \
    bash scripts/agent-exec
}

run_codex_graphite() {
  log "Running Codex Graphite CLI proof"
  AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${GRAPHITE_PROMPT}" \
    bash scripts/agent-exec
}

run_claude_graphite() {
  log "Running Claude Graphite CLI proof"
  AE_TOOL=claude \
    AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${GRAPHITE_PROMPT}" \
    bash scripts/agent-exec
}

run_codex_gh() {
  log "Running Codex GitHub auth proof"
  AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${GH_PROMPT}" \
    bash scripts/agent-exec
}

run_claude_gh() {
  log "Running Claude GitHub auth proof"
  AE_TOOL=claude \
    AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${GH_PROMPT}" \
    bash scripts/agent-exec
}

run_codex_linear() {
  log "Running Codex Linear project-list proof"
  AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${LINEAR_PROMPT}" \
    bash scripts/agent-exec
}

run_claude_linear() {
  log "Running Claude Linear project-list proof"
  AE_TOOL=claude \
    AE_REMOTE="${DEFAULT_REMOTE}" \
    AE_PROMPT="${LINEAR_PROMPT}" \
    bash scripts/agent-exec
}

run_named_test() {
  local test_name="${1}"

  case "${test_name}" in
    build)
      run_build
      ;;
    gt-help)
      run_gt_help
      ;;
    gh-help)
      run_gh_help
      ;;
    linear-help)
      run_linear_help
      ;;
    codex-sha)
      run_codex_sha
      ;;
    claude-sha)
      run_claude_sha
      ;;
    codex-graphite)
      run_codex_graphite
      ;;
    claude-graphite)
      run_claude_graphite
      ;;
    codex-gh)
      run_codex_gh
      ;;
    claude-gh)
      run_claude_gh
      ;;
    codex-linear)
      run_codex_linear
      ;;
    claude-linear)
      run_claude_linear
      ;;
    all)
      run_build
      run_gt_help
      run_gh_help
      run_linear_help
      run_codex_sha
      run_claude_sha
      run_codex_graphite
      run_claude_graphite
      run_codex_gh
      run_claude_gh
      run_codex_linear
      run_claude_linear
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "Unknown test '${test_name}'. Use --help for available tests."
      ;;
  esac
}

main() {
  local -a tests
  local test_name=""

  cd "${REPO_ROOT}"

  if (($# == 0)); then
    tests=(all)
  else
    tests=("$@")
  fi

  for test_name in "${tests[@]}"; do
    run_named_test "${test_name}"
  done
}

main "$@"
