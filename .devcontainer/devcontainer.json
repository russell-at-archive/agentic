{
  "name": "archive-agentic",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Docker-from-Docker: mount the host Docker socket so bin/agent-exec
  // can invoke containerized agents without a nested daemon.
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  // Mount host config repos for each AI coding tool so credentials
  // and settings are available without being committed to the image.
  "mounts": [
    // AWS credentials and config
    {
      "source": "${localEnv:HOME}/.aws",
      "target": "/home/vscode/.aws",
      "type": "bind"
    },
    // Shared Agents directory
    {
      "source": "${localEnv:HOME}/.agents",
      "target": "/home/vscode/.agents",
      "type": "bind"
    },
    // Claude Code
    {
      "source": "${localEnv:HOME}/.claude",
      "target": "/home/vscode/.claude",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.claude.json",
      "target": "/home/vscode/.claude.json",
      "type": "bind"
    },
    // Codex (OpenAI)
    {
      "source": "${localEnv:HOME}/.codex",
      "target": "/home/vscode/.codex",
      "type": "bind"
    },
    // Git config
    {
      "source": "${localEnv:HOME}/.gitconfig",
      "target": "/home/vscode/.gitconfig",
      "type": "bind"
    },    
    {
      "source": "${localEnv:HOME}/.config/git",
      "target": "/home/vscode/.config/git",
      "type": "bind"
    },    
    // Gemini (Google)
    {
      "source": "${localEnv:HOME}/.gemini",
      "target": "/home/vscode/.gemini",
      "type": "bind"
    },
    // Graphite config
    {
      "source": "${localEnv:HOME}/.config/graphite",
      "target": "/home/vscode/.config/graphite",
      "type": "bind"
    },
    // Github Cli Config
    {
      "source": "${localEnv:HOME}/.config/gh",
      "target": "/home/vscode/.config/gh",
      "type": "bind"
    },
    // linear Cli Config
    {
      "source": "${localEnv:HOME}/.config/linear",
      "target": "/home/vscode/.config/linear",
      "type": "bind"
    },
    // Pi (@mariozechner/pi-coding-agent)
    {
      "source": "${localEnv:HOME}/.pi",
      "target": "/home/vscode/.pi",
      "type": "bind"
    },
    // SSH keys and config
    {
      "source": "${localEnv:HOME}/.ssh",
      "target": "/home/vscode/.ssh",
      "type": "bind",
      "options": "readonly"
    }
  ],

  // Forward ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY from host
  // if they are set as environment variables (not in a file).
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "LINEAR_API_KEY": "${localEnv:LINEAR_API_KEY}",
    // HOST_HOME lets bin/agent-exec use host-side paths for Docker bind mounts.
    // Inside the devcontainer $HOME is /home/vscode, which the host Docker
    // daemon cannot see. HOST_HOME is the real host home (e.g. /Users/you),
    // whose subdirectories are already bind-mounted into this container and
    // are visible to Docker Desktop.
    "HOST_HOME": "${localEnv:HOME}"
  },

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "ms-python.python",
        "dbaeumer.vscode-eslint"
      ],
    }
  }
}
